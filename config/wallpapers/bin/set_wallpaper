#!/usr/bin/env bash

filename="$HOME/.wallpaper"

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

# Start hyprpaper if not running
if ! pgrep -x "hyprpaper" > /dev/null; then
    hyprpaper &
fi

# Wait for hyprpaper IPC to be ready before issuing commands.  Newer
# hyprpaper versions do not support the old listpreloaded request, but
# listactive is enough to confirm the IPC socket is responding.
for _ in $(seq 1 20); do
    hyprctl hyprpaper listactive &>/dev/null && break
    sleep 0.5
done

# create the filename if it doesn't exist
if [[ ! -e $filename ]]
then
  touch $filename
fi

cd $SCRIPT_DIR && cd ..

# Get current month for monthly wallpapers
month=$( date '+%Y-%m' )
monthly_wallpaper="Monthly/$month*"

# Collect all wallpapers. Use nullglob so a missing monthly wallpaper does not
# leave a literal Monthly/YYYY-MM* entry that hyprpaper cannot load.
declare -a wallpapers
shopt -s nullglob
wallpapers=( Generic/* $monthly_wallpaper )
shopt -u nullglob
wallpaper_count=${#wallpapers[*]}

if [[ $wallpaper_count -eq 0 ]]; then
  echo "No wallpapers found under $PWD" >&2
  exit 1
fi

# Select random wallpaper (shuf returns 0 to count-1)
index=$( shuf -i 0-$((wallpaper_count - 1)) -n 1 )
if [[ $index -lt $wallpaper_count ]]
then
  current_wallpaper="$PWD/${wallpapers[$index]}"

  # Save absolute path so hyprpaper.conf can preload it on next boot
  echo "$current_wallpaper" > "$filename"

  while IFS= read -r monitor; do
    hyprctl hyprpaper wallpaper "$monitor,$current_wallpaper"
  done < <(hyprctl monitors -j | jq -r '.[].name')

  # Optional: Generate color scheme using wal if available
  if command -v wal &> /dev/null; then
    wal -c
    wal -i "$current_wallpaper" -q
  fi
fi
