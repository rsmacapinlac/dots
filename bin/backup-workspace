#!/bin/bash

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

SOURCE="$HOME/workspace"
BACKUP_SUBDIR="workspace-backups"
KEEP=3

log_info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $1"; }

# Select mount point via fzf, excluding system paths
MOUNT=$(lsblk -o MOUNTPOINT,LABEL,SIZE -nr \
  | grep -v '^$' \
  | grep -Ev '^(/|/boot|/home|/var|/tmp|/proc|/sys|/run/user)\s' \
  | fzf --prompt="Select backup drive: " --height=10 \
  | awk '{print $1}')

if [[ -z "$MOUNT" ]]; then
  log_error "No drive selected. Aborting."
  exit 1
fi

if [[ ! -d "$MOUNT" ]]; then
  log_error "Mount point '$MOUNT' does not exist."
  exit 1
fi

DEST="$MOUNT/$BACKUP_SUBDIR"
mkdir -p "$DEST"

SNAPSHOT="$DEST/$(date +%Y-%m-%d)"

if [[ -d "$SNAPSHOT" ]]; then
  log_warn "Snapshot for today already exists at $SNAPSHOT. Overwriting."
fi

# Detect filesystem and set rsync flags accordingly
FSTYPE=$(findmnt -n -o FSTYPE "$MOUNT")
RSYNC_EXTRA_FLAGS=()
if [[ "$FSTYPE" == "vfat" || "$FSTYPE" == "exfat" || "$FSTYPE" == "ntfs" ]]; then
  log_info "Filesystem:  $FSTYPE (symlinks not supported — skipping)"
  RSYNC_EXTRA_FLAGS+=(--no-links)
else
  log_info "Filesystem:  $FSTYPE"
fi

log_info "Source:      $SOURCE"
log_info "Destination: $SNAPSHOT"

rsync -av --delete "${RSYNC_EXTRA_FLAGS[@]}" "$SOURCE/" "$SNAPSHOT/"

# Prune old snapshots, keep only the last $KEEP
mapfile -t snapshots < <(ls -1d "$DEST"/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9] 2>/dev/null | sort)
count=${#snapshots[@]}

if (( count > KEEP )); then
  to_delete=("${snapshots[@]:0:$(( count - KEEP ))}")
  log_info "Pruning ${#to_delete[@]} old snapshot(s)..."
  rm -rf "${to_delete[@]}"
fi

log_success "Backup complete. Keeping ${KEEP} most recent snapshots."
