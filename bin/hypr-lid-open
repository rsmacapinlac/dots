#!/bin/sh
# Re-enable laptop screen and restore workspaces when undocking with lid open.
state=$(cat /tmp/hypr-lid-state 2>/dev/null)
rm -f /tmp/hypr-lid-state

[ "$state" = "docked" ] || exit 0

hyprctl keyword monitor eDP-1,1920x1080@60.01,0x0,1
sleep 1
hyprctl dispatch moveworkspacetomonitor 1 eDP-1
hyprctl dispatch moveworkspacetomonitor 2 eDP-1
